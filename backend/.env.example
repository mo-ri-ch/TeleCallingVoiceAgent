# Copy this file to .env and fill in your key.
# Required for the AI Agent Playground (Phase 5) to call the Claude API.
ANTHROPIC_API_KEY=

# Required for Sarvam AI speech-to-text / text-to-speech (Phase 9 onward).
SARVAM_API_KEY=

# Public HTTPS URL this server is reachable at, e.g. an ngrok tunnel like
# https://abcd1234.ngrok-free.app. Used only to display the Twilio voice
# webhook URL in the Telephony panel (Phase 11). Leave blank to fall back to
# the request's own host -- which works fine as long as Twilio calls the same
# host shown in the dashboard (e.g. when both are tunneled through ngrok).
PUBLIC_BASE_URL=

# Twilio REST API credentials (Account SID + Auth Token from the Twilio
# Console), required for the warm-transfer flow (Phase 12) to redirect a live
# call into a <Dial> that rings a company's escalation number. Leave blank to
# disable real transfers -- the AI will apologize and keep helping instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=